# Copy to .env and fill in as needed.

# Optional: route all Beanfun HTTP through an HTTP/HTTPS proxy (e.g. a TW exit).
# UNTESTED contingency — the validated host worked WITHOUT a proxy. It may help
# only if the block is geo/region based; if it's datacenter-IP reputation, a TW
# *datacenter* proxy is usually blocked too (you'd need a residential/mobile
# exit). NOTE: all traffic (incl. session/OTP) flows through this proxy — only
# use one you trust. No SOCKS support.
# Example: BEANFUN_PROXY=http://user:pass@tw-proxy.example.com:8080
BEANFUN_PROXY=

# Verbose request logging (1 = on). Never logs cookie values / OTP / tokens.
BEANFUN_DEBUG=0

# --- Discord (M1) ---------------------------------------------------------
# From https://discord.com/developers/applications -> your app -> Bot.
DISCORD_TOKEN=
# Application (client) ID — app -> General Information -> Application ID.
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to ONE server (dev only).
# WARNING: guild-scoped commands NEVER appear in DMs. To use /login in the bot
# DM, leave this BLANK so commands register globally (can take up to ~1h to
# appear the first time). Right-click your server icon -> Copy Server ID
# (needs Developer Mode on).
DISCORD_GUILD_ID=

# Optional: mark commands user-installable (1 = on) so a user can install the
# app to their own account and run /login in any DM without sharing a server.
# REQUIRES enabling "User Install" in Developer Portal -> Installation first,
# otherwise registration fails. Default off (guild-install only).
DISCORD_USER_INSTALL=0

# --- Access control (recommended) -----------------------------------------
# The gate only stops strangers using THIS host to run their own Beanfun logins
# (each user only ever sees their own OTP — cross-user theft is impossible).
# A user is authorized if ANY mechanism below grants them access. If ALL THREE
# are blank, the bot is open to anyone who can reach it.
#
# RECOMMENDED (DM-friendly, no shared server needed): a shared invite code.
# A new friend runs `/login code:<this value>` ONCE; the bot then remembers them
# (enrollment persisted in the DB) and they never re-enter it. Adding a friend =
# handing them this code once — no .env edits, no restart, no server to join.
# NOTE: enrollment persists only if SESSION_ENCRYPTION_KEY is set (shared DB);
# otherwise friends must re-enter the code after a restart.
ACCESS_CODE=
# Optional: members of this guild auto-pass (for users who DO share a server).
# The bot must be in this guild. Right-click the server icon -> Copy Server ID.
REQUIRED_GUILD_ID=
# Optional static allow set (comma/space-separated user IDs), e.g. yourself or a
# friend you don't want to hand a code to.
ALLOWED_DISCORD_IDS=

# --- Persistence (M2) -----------------------------------------------------
# 32-byte key (64 hex chars) that encrypts stored sessions at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
# If left blank, the bot runs memory-only and sessions are lost on restart.
SESSION_ENCRYPTION_KEY=
# Where the encrypted SQLite DB lives. Defaults to data/beanycord.sqlite.
# NOTE: at-rest encryption only protects the DB if it leaks ALONE. The key sits
# in this .env on the SAME host, so a host compromise = full session loss.
# Keep `.env` and the data/ dir chmod 600/700, owned by one user, and do NOT
# back them up together.
SESSION_DB_PATH=
# Persisted sessions not refreshed within this many days are dropped on load
# (caps how long a leaked DB stays useful). 0 disables expiry. Default 30.
SESSION_MAX_AGE_DAYS=30
